---
import '../styles/global.css';

const {
  title = 'Props Lab — 別府の事業者と、長く歩くIT顧問',
  description = '別府の中小企業のための、月額制IT顧問。ホームページ制作から日々の業務相談まで、「ちょっと聞ける人」が社内にいる安心を月額制でお届けします。',
  ogImage = '/og-default.png',
  pathname = Astro.url.pathname,
} = Astro.props;

const siteUrl = 'https://props-lab.com';
const canonical = new URL(pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();

const navItems = [
  { href: '/service', label: 'サービス' },
  { href: '/pricing', label: '料金' },
  { href: '/about', label: '会社案内' },
  { href: '/contact', label: 'お問い合わせ' },
];

const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OGP -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Props Lab" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;600;800&family=Zen+Kaku+Gothic+New:wght@400;500;700&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <meta name="theme-color" content="#FAF7F2" />
  </head>
  <body>
    <a class="skip-link" href="#main">本文へスキップ</a>

    <header class="site-header">
      <div class="site-header__inner container">
        <a href="/" class="site-logo" aria-label="Props Lab ホーム">
          <span class="site-logo__dot" aria-hidden="true"></span>Props Lab
        </a>

        <nav class="site-nav" aria-label="グローバルナビゲーション">
          <ul class="site-nav__list">
            {
              navItems.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class:list={[
                      'site-nav__link',
                      { 'is-current': pathname === item.href || pathname === item.href + '/' },
                    ]}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner container">
        <div class="site-footer__brand">
          <div class="site-logo">
            <span class="site-logo__dot" aria-hidden="true"></span>Props Lab
          </div>
          <p class="site-footer__tagline">別府の事業者と、長く歩く。</p>
          <p class="en-label site-footer__en">For Beppu Businesses</p>
        </div>

        <nav class="site-footer__nav" aria-label="フッターナビゲーション">
          <ul>
            {
              navItems.map((item) => (
                <li>
                  <a href={item.href}>{item.label}</a>
                </li>
              ))
            }
          </ul>
        </nav>

        <div class="site-footer__meta">
          <p class="en-label">Beppu · Oita · Japan</p>
          <p class="site-footer__copy">© {currentYear} Props Lab</p>
        </div>
      </div>
    </footer>

    <style>
      /* Skip link */
      .skip-link {
        position: absolute;
        top: -100px;
        left: 16px;
        background: var(--text);
        color: var(--bg);
        padding: 8px 16px;
        border-radius: 4px;
        font-size: 13px;
        z-index: 1000;
      }
      .skip-link:focus {
        top: 16px;
      }

      /* =========================
         Header
         ========================= */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--bg) 88%, transparent);
        backdrop-filter: saturate(140%) blur(8px);
        -webkit-backdrop-filter: saturate(140%) blur(8px);
      }
      .site-header__inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 72px;
      }

      .site-logo {
        font-family: var(--font-serif);
        font-weight: 800;
        font-size: 20px;
        letter-spacing: 0.02em;
        color: var(--text);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .site-logo__dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        background: var(--accent-red);
        border-radius: 50%;
      }

      .site-nav__list {
        list-style: none;
        display: flex;
        gap: clamp(14px, 2.4vw, 32px);
        align-items: center;
      }
      .site-nav__link {
        font-family: var(--font-sans);
        font-size: 14px;
        font-weight: 500;
        color: var(--text-muted);
        position: relative;
        padding: 6px 0;
        transition: color 0.2s ease;
      }
      .site-nav__link:hover {
        color: var(--text);
      }
      .site-nav__link.is-current {
        color: var(--text);
      }
      .site-nav__link.is-current::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--accent-red);
      }

      @media (max-width: 600px) {
        .site-header__inner {
          height: 64px;
        }
        .site-logo {
          font-size: 18px;
        }
        .site-nav__list {
          gap: 14px;
        }
        .site-nav__link {
          font-size: 12px;
        }
      }

      /* =========================
         Footer
         ========================= */
      .site-footer {
        margin-top: 120px;
        border-top: 1px solid var(--border);
        background: var(--bg-subtle);
      }
      .site-footer__inner {
        display: grid;
        grid-template-columns: 1fr;
        gap: 40px;
        padding-top: 64px;
        padding-bottom: 48px;
      }
      @media (min-width: 768px) {
        .site-footer__inner {
          grid-template-columns: 1.3fr 1fr 1fr;
          gap: 48px;
        }
      }

      .site-footer__brand .site-logo {
        margin-bottom: 16px;
      }
      .site-footer__tagline {
        font-family: var(--font-serif);
        font-size: 15px;
        color: var(--text-muted);
        margin-bottom: 12px;
      }
      .site-footer__en {
        font-size: 10px;
      }

      .site-footer__nav ul {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .site-footer__nav a {
        font-size: 14px;
        color: var(--text-muted);
        transition: color 0.2s ease;
      }
      .site-footer__nav a:hover {
        color: var(--accent-red);
      }

      .site-footer__meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }
      .site-footer__copy {
        font-family: var(--font-en);
        font-size: 12px;
        color: var(--text-subtle);
      }
      @media (min-width: 768px) {
        .site-footer__meta {
          align-items: flex-end;
          text-align: right;
        }
      }
    </style>
  </body>
</html>
