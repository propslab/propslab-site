---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Props Lab — 別府の事業者と、長く歩くIT顧問"
  description="別府の中小企業のための、月額制IT顧問。ホームページを作って終わり、ではなく。「ちょっと聞ける人」が社内にいる安心を月額制でお届けします。"
>
  <section class="fv" aria-labelledby="fv-heading">
    <div class="fv__bg" aria-hidden="true"></div>
    <div class="fv__noise" aria-hidden="true"></div>

    <div class="fv__stamp" aria-hidden="true">
      別府発<br />令和8年<br />創業
    </div>

    <div class="fv__content container">
      <span class="fv__kicker">● 月額制 IT顧問</span>

      <h1 class="fv__headline" id="fv-heading">
        別府の事業者と、<br />
        <span class="fv__underline">長く歩く</span>、<br />
        <span class="fv__accent">IT顧問。</span>
      </h1>

      <p class="fv__sub">
        ホームページを作って終わり、ではなく。<br />
        日々の問い合わせ、予約サイトの設定、新しい仕組みの選び方。<br />
        「ちょっと聞ける人」が社内にいる安心を、月額制でお届けします。
      </p>

      <div class="fv__cta-row">
        <a href="/service" class="fv__cta-primary">サービスを見る →</a>
        <a href="/contact" class="fv__cta-secondary">無料相談はこちら</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .fv {
    position: relative;
    overflow: hidden;
    padding: clamp(48px, 9vw, 112px) 0 clamp(80px, 12vw, 140px);
    /* Visually connect with sticky header */
    margin-top: -72px;
    padding-top: calc(72px + clamp(48px, 9vw, 112px));
  }
  @media (max-width: 600px) {
    .fv {
      margin-top: -64px;
      padding-top: calc(64px + clamp(48px, 9vw, 112px));
    }
  }

  .fv__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(ellipse 800px 400px at 80% 20%, rgba(200, 75, 49, 0.08), transparent 60%),
      radial-gradient(ellipse 600px 300px at 10% 80%, rgba(45, 90, 74, 0.06), transparent 60%);
  }

  .fv__noise {
    position: absolute;
    inset: 0;
    opacity: 0.4;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9'/%3E%3CfeColorMatrix values='0 0 0 0 0.5 0 0 0 0 0.4 0 0 0 0 0.3 0 0 0 0.08 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  .fv__content {
    position: relative;
    z-index: 1;
  }

  /* Kicker (red pill) */
  .fv__kicker {
    display: inline-block;
    font-family: var(--font-en);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-red);
    margin-bottom: 32px;
    padding: 8px 16px;
    border: 1px solid var(--accent-red);
    border-radius: 100px;
  }

  /* Headline */
  .fv__headline {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: clamp(36px, 7vw, 72px);
    line-height: 1.3;
    letter-spacing: 0.02em;
    margin-bottom: 40px;
  }
  .fv__accent {
    color: var(--accent-red);
  }
  .fv__underline {
    position: relative;
    display: inline-block;
  }
  .fv__underline::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    right: 0;
    height: 10px;
    background: var(--accent-red-soft);
    z-index: -1;
  }

  /* Sub copy */
  .fv__sub {
    font-size: 16px;
    line-height: 1.95;
    color: var(--text-muted);
    max-width: 560px;
    margin-bottom: 48px;
  }
  @media (max-width: 600px) {
    .fv__sub {
      font-size: 15px;
    }
    /* Tighter line breaks on mobile — let the text wrap naturally */
    .fv__sub br {
      display: none;
    }
  }

  /* CTA row */
  .fv__cta-row {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    align-items: center;
  }
  .fv__cta-primary {
    background: var(--text);
    color: var(--bg);
    padding: 16px 32px;
    border-radius: 100px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 15px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .fv__cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px -12px rgba(26, 26, 26, 0.4);
  }
  .fv__cta-secondary {
    color: var(--text);
    font-size: 14px;
    border-bottom: 1px solid var(--text);
    padding-bottom: 4px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .fv__cta-secondary:hover {
    color: var(--accent-red);
    border-bottom-color: var(--accent-red);
  }

  /* Stamp */
  .fv__stamp {
    position: absolute;
    top: clamp(96px, 12vw, 140px);
    right: clamp(16px, 5vw, 64px);
    width: 110px;
    height: 110px;
    border: 2px solid var(--accent-green);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: rotate(-12deg);
    color: var(--accent-green);
    font-family: var(--font-serif);
    font-size: 11px;
    text-align: center;
    line-height: 1.5;
    padding: 12px;
    z-index: 2;
  }
  @media (max-width: 600px) {
    .fv__stamp {
      width: 78px;
      height: 78px;
      font-size: 9px;
      top: 88px;
      right: 12px;
      padding: 8px;
    }
  }
</style>
